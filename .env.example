# MongoDB Atlas Connection String
# Replace <username>, <password>, and <cluster-url> with your MongoDB Atlas credentials
# Get your connection string from MongoDB Atlas: Database > Connect > Connect your application
#
# Example: mongodb+srv://myuser:mypassword@cluster0.xxxxx.mongodb.net/cinema?retryWrites=true&w=majority
#
# For setup instructions, see QUICKSTART.md
MONGODB_URI=mongodb+srv://admin:<dbpassword>@cluster0.51a7doa.mongodb.net/cinema?retryWrites=true&w=majority

# Server Port (optional, defaults to 3000)
PORT=3000
HOST='127.0.0.1'
JWT_SECRET=replace-with-a-strong-secret
ADMIN_EMAIL=admin@kino.local
ADMIN_PASSWORD=ChangeThisPassword
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Apollo Kino API URL
APOLLO_KINO_API_URL=https://www.apollokino.ee/xml
